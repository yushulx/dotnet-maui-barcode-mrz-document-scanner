@page "/"
@inject IJSRuntime JSRuntime
@inject NavigationManager NavigationManager
@using Microsoft.AspNetCore.Components.Web;

<div class="license-container">
    <h2>Activate SDK</h2>
    <p class="info-text">
        Get a License key from
        <a href="https://www.dynamsoft.com/customer/license/trialLicense/?product=dcv&package=cross-platform"
           target="_blank">here</a>
    </p>
    <div class="input-group">
        <input type="text" @bind="licenseKey" placeholder="Enter your license key" class="license-input" />
        <button class="btn btn-activate" @onclick="Activate" disabled="@isActivating">
            @(isActivating ? "Activating..." : "Activate")
        </button>
    </div>

    @if (!string.IsNullOrEmpty(statusMessage))
    {
        <p class="status-message @(isActivated ? "success" : "error")">@statusMessage</p>
    }

    @if (isActivated)
    {
        <div class="nav-buttons">
            <button class="btn btn-nav" @onclick='() => NavigationManager.NavigateTo("reader")'>
                File Reader
            </button>
            <button class="btn btn-nav" @onclick='() => NavigationManager.NavigateTo("scanner")'>
                Camera Scanner
            </button>
        </div>
    }
</div>

@if (isLoading)
{
    <div class="loading-overlay">
        <div class="spinner"></div>
    </div>
}

@code {
    private string licenseKey = "DLS2eyJoYW5kc2hha2VDb2RlIjoiMjAwMDAxLTE2NDk4Mjk3OTI2MzUiLCJvcmdhbml6YXRpb25JRCI6IjIwMDAwMSIsInNlc3Npb25QYXNzd29yZCI6IndTcGR6Vm05WDJrcEQ5YUoifQ==";
    private bool isActivating = false;
    private bool isActivated = false;
    private bool isLoading = false;
    private string statusMessage = "";
    private DotNetObjectReference<Index> objRef;

    protected override void OnInitialized()
    {
        objRef = DotNetObjectReference.Create(this);
    }

    private async Task Activate()
    {
        if (string.IsNullOrWhiteSpace(licenseKey)) return;
        isActivating = true;
        statusMessage = "";
        StateHasChanged();

        try
        {
            isActivated = await JSRuntime.InvokeAsync<bool>("jsFunctions.initSDK", objRef, licenseKey);
            statusMessage = isActivated ? "SDK activated successfully!" : "SDK activation failed.";
        }
        catch (Exception ex)
        {
            statusMessage = "Error: " + ex.Message;
        }

        isActivating = false;
        StateHasChanged();
    }

    [JSInvokable]
    public void OnLoadingChanged(bool loading)
    {
        isLoading = loading;
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        objRef?.Dispose();
    }
}
