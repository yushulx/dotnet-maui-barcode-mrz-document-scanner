{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "maui: Build Android Device",
      "type": "maui",
      "project": "${workspaceFolder}/BarcodeScanner/BarcodeScanner.csproj",
      "targetFramework": "net8.0-android",
      "configuration": "Debug",
      "problemMatcher": "$msCompile"
    },
    {
      "label": "maui: Build iOS Device",
      "type": "maui",
      "project": "${workspaceFolder}/BarcodeScanner/BarcodeScanner.csproj",
      "targetFramework": "net8.0-ios",
      "configuration": "Debug",
      "problemMatcher": "$msCompile"
    },
    {
      "label": "maui: Build MacCatalyst",
      "type": "maui",
      "project": "${workspaceFolder}/BarcodeScanner/BarcodeScanner.csproj",
      "targetFramework": "net8.0-maccatalyst",
      "configuration": "Debug",
      "problemMatcher": "$msCompile",
      "group": {
        "kind": "build",
        "isDefault": true
      }
    }
  ]
}
